<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sm_player.sm_proj_gebski_11b.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
        <children>
            <Button fx:id="loadButton" text="Load" />
            <TextField fx:id="pathTextField" />
            <Button fx:id="resetButton" mnemonicParsing="false" text="Reset" />
         <VBox prefHeight="100.0" prefWidth="32.0">
            <children>
               <Button fx:id="mixButton" mnemonicParsing="false" text="🔀" />
               <Button fx:id="unmixButton" mnemonicParsing="false" text="⮆" />
            </children>
         </VBox>
        </children>
    </HBox>

    <ListView fx:id="musicListView" prefHeight="400.0" prefWidth="600.0" />
</VBox>
